# Supabase project settings (Project Settings → API in the Supabase dashboard).
# The anon key is safe to expose in client code — access is enforced by Row Level Security.
# Never put the service_role key here or in any VITE_* variable — it must
# only ever exist as an Edge Function secret, never shipped to the browser.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
